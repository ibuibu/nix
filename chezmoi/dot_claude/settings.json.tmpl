{
  "env": {
    "ANTHROPIC_MODEL": "claude-sonnet-5",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "additionalDirectories": [
      "~/ghq/github.com",
      "~/worktrees"
    ],
    "allow": [
      "Bash:gh pr diff",
      "Bash:gh pr view",
      "Bash:gh pr checks",
      "Bash:gh workflow view",
      "Bash:gh run view",
      "Bash:gh api",
      "Bash:gh repo view",
      "Bash:cargo clippy",
      "Bash:cargo check",
      "Bash:cargo build",
      "Bash:cargo test",
      "Bash:cargo nextest",
      "Bash:cargo run",
      "Bash:cargo fmt",
      "Bash:cargo update",
      "Bash:cargo tree",
      "Bash:npx tsc --noemit",
      "Bash:npm run",
      "Bash:npm view",
      "Bash:npm config",
      "Bash:npm ls",
      "Bash:docker compose",
      "Bash:find",
      "Bash:sqlfluff",
      "Bash:ls",
      "Bash:wc",
      "Bash:git branch --show-current",
      "Bash:git branch -a",
      "Bash:git show",
      "Bash:git diff",
      "Bash:git fetch",
      "Bash:git switch",
      "Bash:git checkout",
      "Bash:git ls-tree",
      "Bash:cd",
      "Bash(curl:*)",
      "WebFetch:domain:github.com",
      "WebFetch:domain:docs.rs",
      "WebFetch:domain:crates.io",
      "WebFetch:domain:serde.rs",
      "WebFetch:domain:raw.githubusercontent.com",
      "mcp__sentry__search_events",
      "mcp__sentry__search_issues",
      "mcp__sentry__get_sentry_resource",
      "mcp__google-sheets__get_sheet_data",
      "mcp__google-sheets__list_sheets",
      "mcp__google-sheets__batch_update_cells",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_navigate",
      "Read",
      "Search",
      "Grep"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(brew install:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(wget:*)",
      "Bash(git clone:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(git remote remove:*)",
      "Bash(git remote rename:*)",
      "Bash(git clean:*)",
      "Bash(git clean -f:*)",
      "Bash(docker push:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Read(//**/.env*)",
      "Read(//**/secrets/**)",
      "Read(//**/credentials*)",
      "Read(//**/*.key)",
      "Read(//**/*.pem)",
      "Read(//**/*.tfvars)",
      "Read(//**/*.tfstate*)",
      "Read(//**/.git-credentials)",
      "Read(//**/.netrc)",
      "Read(//**/.npmrc)",
      "Read(//**/id_rsa*)",
      "Read(//**/id_ed25519*)",
      "Read(//**/*kubeconfig*)",
      "Read(//**/*service-account*.json)",
      "Read(//**/*gcp-key*.json)",
      "Read(//**/application_default_credentials.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Write(//**/.env*)",
      "Write(//**/secrets/**)",
      "Write(//**/credentials*)",
      "Write(//**/*.key)",
      "Write(//**/*.pem)",
      "Write(//**/*.tfvars)",
      "Write(//**/*.tfstate*)",
      "Write(//**/.git-credentials)",
      "Write(//**/.netrc)",
      "Write(//**/.npmrc)",
      "Write(//**/id_rsa*)",
      "Write(//**/id_ed25519*)",
      "Write(//**/*kubeconfig*)",
      "Write(//**/*service-account*.json)",
      "Write(//**/*gcp-key*.json)",
      "Write(//**/application_default_credentials.json)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.docker/config.json)",
      "Write(~/.config/**)",
      "Write(~/.kube/**)",
      "Write(~/.config/gcloud/**)",
      "Write(~/.zshrc)",
      "Write(~/.zshenv)",
      "Write(~/.bashrc)",
      "Write(~/.bash_profile)",
      "Edit(//**/.env*)",
      "Edit(//**/.git-credentials)",
      "Edit(//**/.netrc)",
      "Edit(//**/.npmrc)",
      "Edit(//**/*.tfvars)",
      "Edit(//**/*service-account*.json)",
      "Edit(//**/*gcp-key*.json)",
      "Edit(//**/application_default_credentials.json)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.config/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.zshrc)",
      "Edit(~/.zshenv)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)"
    ],
    "defaultMode": "auto"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "availableModels": [
    "opus",
    "sonnet",
    "haiku"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.prompt // empty' | grep -qE '^/autofix-pr(\\s|$)' && echo '{\"continue\":false,\"stopReason\":\"/autofix-pr is denied by project policy. Use /nodex-plugin:resolve-review for local PR review handling.\"}' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if grep -qi microsoft /proc/version 2>/dev/null; then powershell.exe '(New-Object System.Media.SoundPlayer \"$env:windir\\Media\\tada.wav\").PlaySync()'; elif [ \"$(uname)\" = \"Darwin\" ]; then afplay /System/Library/Sounds/Hero.aiff; fi"
          },
          {
            "type": "command",
            "command": "xmux notify --title 'Claude Code' --body 'Task completed' 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if grep -qi microsoft /proc/version 2>/dev/null; then powershell.exe '(New-Object System.Media.SoundPlayer \"$env:windir\\Media\\notify.wav\").PlaySync()'; elif [ \"$(uname)\" = \"Darwin\" ]; then afplay /System/Library/Sounds/Ping.aiff; fi"
          },
          {
            "type": "command",
            "command": "xmux notify --title 'Claude Code' --body 'Ready for input' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r 'def fmt(n): if n == null then \"?\" elif n >= 1000000 then \"\\((n/100000|floor)/10)M\" elif n >= 1000 then \"\\((n/100|floor)/10)k\" else \"\\(n)\" end; (.context_window.current_usage // {}) as $u | (($u.input_tokens // 0) + ($u.output_tokens // 0) + ($u.cache_creation_input_tokens // 0) + ($u.cache_read_input_tokens // 0)) as $used | \"\\(.cwd) | \\(.model.display_name) | ctx: \\(fmt($used))/\\(fmt(.context_window.context_window_size)) (\\(.context_window.used_percentage // 0 | floor)%)\"'"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "mcpServers": {
    "gcloud": {
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"]
    },
    "observability": {
      "command": "npx",
      "args": ["-y", "@google-cloud/observability-mcp"]
    },
    "storage": {
      "command": "npx",
      "args": ["-y", "@google-cloud/storage-mcp"]
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
